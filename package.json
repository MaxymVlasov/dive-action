{
  "name": "dive-action",
  "version": "1.6.0",
  "description": "[![Release][release-badge]][release] [![GitHub Marketplace][marketplace-badge]][marketplace] [![License][license-badge]][license]",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxymVlasov/dive-action.git"
  },
  "keywords": [
    "actions",
    "typescript",
    "node",
    "docker"
  ],
  "author": "yuichielectric",
  "maintainers": [
    {
      "name": "MaxymVlasov"
    }
  ],
  "license": "MIT",
  "engines": {
    "node": "^20.12.0 || ^22.0.0 || >=24.0.0"
  },
  "bugs": {
    "url": "https://github.com/MaxymVlasov/dive-action/issues"
  },
  "homepage": "https://github.com/MaxymVlasov/dive-action#readme",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/github": "^8.0.1",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.3"
  }
}
